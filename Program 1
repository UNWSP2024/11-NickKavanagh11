import tkinter as tk

def main():
    # Create main window
    root = tk.Tk()
    root.title("Favorite Saying")

    # Create a label with your favorite saying
    message = tk.Label(root, text="Stay curious, keep building.", 
                       font=("Arial", 14), wraplength=300)
    message.pack(padx=20, pady=20)

    # Run the GUI loop
    root.mainloop()

if __name__ == "__main__":
    main()
