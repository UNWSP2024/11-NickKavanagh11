import tkinter as tk
from tkinter import messagebox

def show_info():
    # Display name and fictional address
    messagebox.showinfo("My Info", "Name: Nick Kavanagh\nAddress: 123 Code Lane\nPython City, PC 12345")

def main():
    # Create main window
    root = tk.Tk()
    root.title("Information Viewer")

    # Create Show Info button
    show_button = tk.Button(root, text="Show Info", command=show_info)
    show_button.pack(padx=20, pady=10)

    # Create Quit button
    quit_button = tk.Button(root, text="Quit", command=root.destroy)
    quit_button.pack(padx=20, pady=10)

    # Run the GUI loop
    root.mainloop()

if __name__ == "__main__":
    main()
